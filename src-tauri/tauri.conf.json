{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AeroTask",
  "version": "0.1.0",
  "identifier": "com.patha.aerotask",
  "build": {
    "beforeDevCommand": "D:\\Programming\\nodejs\\npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "D:\\Programming\\nodejs\\npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AeroTask",
        "width": 420,
        "height": 720,
        "minWidth": 420,
        "minHeight": 720,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
